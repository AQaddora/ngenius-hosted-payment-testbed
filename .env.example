PORT=3000
APP_BASE_URL=http://localhost:3000

# ─── Sandbox ────────────────────────────────────────────────────────────────
# Default gateway (do not change unless N-Genius updates the URL)
NGENIUS_BASE_URL=https://api-gateway.sandbox.ngenius-payments.com

# From the N-Genius Merchant Portal → Settings → Integrations → Merchant Service Accounts
NGENIUS_API_KEY=

# From the N-Genius Merchant Portal → Settings → Integrations → Outlets
NGENIUS_OUTLET_ID=

# ─── Production (only after merchant go-live approval) ──────────────────────
NGENIUS_PROD_BASE_URL=https://api-gateway.ngenius-payments.com
NGENIUS_PROD_API_KEY=
NGENIUS_PROD_OUTLET_ID=
